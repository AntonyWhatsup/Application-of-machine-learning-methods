   "source": [
    "# Inicjalizacja i trenowanie modelu K-Means dla 4 klastrów\n",
    "kmeans = KMeans(n_clusters=4, random_state=42, n_init='auto')\n",
    "df_pca['Cluster_KMeans'] = kmeans.fit_predict(X_scaled)\n",
    "\n",
    "# Obliczanie metryki Silhouette Score (im bliżej 1, tym lepsze grupowanie)\n",
    "sil_score_kmeans = silhouette_score(X_scaled, df_pca['Cluster_KMeans'])\n",
    "print(f\"K-Means Silhouette Score: {sil_score_kmeans:.4f}\")\n",
    "\n",
    "# Wizualizacja wyników K-Means\n",
    "plt.figure(figsize=(10, 8))\n",
    "sns.scatterplot(\n",
    "    x='Component_1', \n",
    "    y='Component_2', \n",
    "    hue='Cluster_KMeans', \n",
    "    palette='viridis', \n",
    "    data=df_pca, \n",
    "    alpha=0.6, \n",
    "    s=20\n",
    ")\n",
    "plt.title(f\"K-Means Clustering (k=4) - Silhouette Score: {sil_score_kmeans:.4f}\", fontsize=14)\n",
    "plt.xlabel(\"Principal Component 1\")\n",
    "plt.ylabel(\"Principal Component 2\")\n",
    "plt.legend(title='Cluster')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
