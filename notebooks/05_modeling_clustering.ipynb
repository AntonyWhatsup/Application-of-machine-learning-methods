    "# 1. Prepare data for clustering (Drop all target variables)\n",
    "cols_to_drop = ['SalaryUSD', 'SalaryUSD_Log']\n",
    "\n",
    "# Add encoded target if it exists from the classification phase\n",
    "if 'Target_Encoded' in df.columns:\n",
    "    cols_to_drop.append('Target_Encoded')\n",
    "    \n",
    "# Add original career plans columns\n",
    "career_cols = [col for col in df.columns if 'CareerPlans' in col]\n",
    "cols_to_drop.extend(career_cols)\n",
    "\n",
    "# Ensure we only drop columns that actually exist in the dataframe\n",
    "cols_to_drop = [col for col in cols_to_drop if col in df.columns]\n",
    "\n",
    "X_cluster = df.drop(columns=cols_to_drop)\n",
    "print(f\"Features ready for clustering: {X_cluster.shape[1]} columns\")\n",
    "\n",
    "# 2. Dimensionality Reduction (TruncatedSVD for sparse data)\n",
    "print(\"Reducing dimensionality down to 2 components...\")\n",
    "svd = TruncatedSVD(n_components=2, random_state=42)\n",
    "X_reduced = svd.fit_transform(X_cluster)\n",
    "\n",
    "# 3. Scaling the reduced components (Crucial for distance-based algorithms like K-Means/DBSCAN)\n",
    "scaler = StandardScaler()\n",
    "X_scaled = scaler.fit_transform(X_reduced)\n",
    "\n",
    "# Create a new DataFrame for our 2D visualization\n",
    "df_pca = pd.DataFrame(data=X_scaled, columns=['Component_1', 'Component_2'])\n",
    "\n",
    "print(\"Dimensionality reduction complete!\")\n",
    "\n",
    "# 4. Plot the base distribution before clustering\n",
    "plt.figure(figsize=(10, 8))\n",
    "sns.scatterplot(x='Component_1', y='Component_2', data=df_pca, alpha=0.3, s=15, color='#4c72b0')\n",
    "plt.title(\"Data Distribution in 2D Space (TruncatedSVD)\", fontsize=14)\n",
    "plt.xlabel(\"Principal Component 1\")\n",
    "plt.ylabel(\"Principal Component 2\")\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
