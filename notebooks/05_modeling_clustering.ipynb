    "# Initialize and train the DBSCAN model\n",
    "# The eps and min_samples parameters define how dense a cluster must be.\n",
    "dbscan = DBSCAN(eps=0.3, min_samples=15)\n",
    "df_pca['Cluster_DBSCAN'] = dbscan.fit_predict(X_scaled)\n",
    "\n",
    "# Check how many clusters were found (ignoring the noise marked as -1)\n",
    "n_clusters_dbscan = len(set(df_pca['Cluster_DBSCAN'])) - (1 if -1 in df_pca['Cluster_DBSCAN'].values else 0)\n",
    "print(f\"DBSCAN found {n_clusters_dbscan} clusters.\")\n",
    "\n",
    "# Calculate the Silhouette Score only for points that are not considered noise\n",
    "if n_clusters_dbscan > 1:\n",
    "    mask = df_pca['Cluster_DBSCAN'] != -1\n",
    "    sil_score_dbscan = silhouette_score(X_scaled[mask], df_pca['Cluster_DBSCAN'][mask])\n",
    "    print(f\"DBSCAN Silhouette Score (excluding noise): {sil_score_dbscan:.4f}\")\n",
    "else:\n",
    "    print(\"DBSCAN found too few clusters to calculate a Silhouette Score.\")\n",
    "\n",
    "# Visualize the DBSCAN results\n",
    "plt.figure(figsize=(10, 8))\n",
    "sns.scatterplot(\n",
    "    x='Component_1', \n",
    "    y='Component_2', \n",
    "    hue='Cluster_DBSCAN', \n",
    "    palette='tab10', \n",
    "    data=df_pca, \n",
    "    alpha=0.6, \n",
    "    s=20\n",
    ")\n",
    "plt.title(\"DBSCAN Clustering (Noise marked as -1)\", fontsize=14)\n",
    "plt.xlabel(\"Principal Component 1\")\n",
    "plt.ylabel(\"Principal Component 2\")\n",
    "plt.legend(title='Cluster')\n",
    "plt.tight_layout()\n",
    "plt.show()"
